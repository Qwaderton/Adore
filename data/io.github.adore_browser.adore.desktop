[Desktop Entry]
Name=Adore Web Browser
GenericName=Web Browser
Comment=The missing browser for lightweight X11 desktop environments
Exec=adore %U
Icon=io.github.adore-browser.adore
Terminal=false
Type=Application
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;x-scheme-handler/http;x-scheme-handler/https;
Keywords=browser;web;internet;webkit;
StartupNotify=true
StartupWMClass=adore